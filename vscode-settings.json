{
    "workbench.colorTheme": "Default Dark Modern",
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": true,
    "editor.defaultFormatter": "rubocop.vscode-rubocop",
