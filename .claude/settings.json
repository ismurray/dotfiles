{
  "model": "opus",
  "tui": "default",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "Task"
    ]
  },
  "extraKnownMarketplaces": {
    "betterup-engineering": {
      "source": {
        "source": "github",
        "repo": "betterup/betterup-claude-code-toolkit"
      }
    }
  },
  "enabledPlugins": {
    "atlassian-cli@betterup-engineering": true,
    "platoon-harness@betterup-engineering": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\""
  }
}
